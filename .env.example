# Copy to `.env` and fill in before `docker compose up -d --build`.

# Connection string for the shared self-hosted Postgres instance.
# Use a dedicated database + credentials for Aiportal (same pattern as
# pf-cwh / tasktracker — independent account, shared host).
DATABASE_URL=postgres://aiportal_user:CHANGE_ME@postgres-host:5432/aiportal

# Admin password for the portal's admin panel and private-site unlock.
# The source falls back to a hardcoded default (85097110) if this is unset —
# always set a real value in production.
ADMIN_PASSWORD=CHANGE_ME

# Host port the portal is published on (nginx container listens on 80 inside).
HOST_PORT=3000
